{
    "name": "smaacg/anime-sync-pro",
    "description": "Anime Sync Pro – WordPress plugin for syncing anime data from AniList, Bangumi, MAL.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0",
        "overtrue/php-opencc": "^1.3"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "AnimeSyncPro\\": "includes/"
        }
    }
}
